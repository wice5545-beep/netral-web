DATABASE_URL="postgresql://postgres:password@localhost:5432/netral"
SESSION_SECRET="generate-a-32-char-secret-here"

# Supabase — requis pour l'auth Google OAuth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# URL publique de l'app (pour le redirect OAuth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI providers
MISTRAL_API_KEY="your-mistral-api-key"
GROQ_API_KEY="your-groq-api-key"
CEREBRAS_API_KEY="your-cerebras-api-key"
GEMINI_API_KEY="your-gemini-api-key"
# NVIDIA_API_KEY="your-nvidia-api-key"  # deprecated: NTRL 2.0 now uses Cerebras

# Web search (optionnel — Tavily offre 1000 req/mois gratuit)
TAVILY_API_KEY="your-tavily-api-key"
# Jina AI Reader (optionnel — améliore la lecture des pages)
JINA_API_KEY="your-jina-api-key"
